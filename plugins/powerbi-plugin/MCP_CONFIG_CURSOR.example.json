{
  "mcpServers": {
    "powerbi": {
      "comment": "powerbi-plugin — credenciais Azure via env. Publish exige aprovação.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-powerbi"],
      "env": {
        "POWERBI_CLIENT_ID": "${POWERBI_CLIENT_ID}",
        "POWERBI_CLIENT_SECRET": "${POWERBI_CLIENT_SECRET}",
        "POWERBI_TENANT_ID": "${POWERBI_TENANT_ID}"
      }
    }
  }
}
