{
  "mcpServers": {
    "clickup": {
      "comment": "clickup-plugin — não alterar status sem pedido explícito.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-clickup"],
      "env": {
        "CLICKUP_API_TOKEN": "${CLICKUP_API_TOKEN}",
        "CLICKUP_TEAM_ID": "${CLICKUP_TEAM_ID}"
      }
    }
  }
}
