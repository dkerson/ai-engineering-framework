{
  "mcpServers": {
    "postgres": {
      "comment": "postgres-plugin — RAG/pgvector. POSTGRES_DATABASE_URL via env.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_DATABASE_URL}"
      }
    }
  }
}
