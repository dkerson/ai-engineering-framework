# SQL Server — Environment Variables (example)
# Copiar para .env local. NUNCA commitar .env com valores reais.

MSSQL_SERVER=localhost
MSSQL_DATABASE=UmbraDb
MSSQL_USER=
MSSQL_PASSWORD=
SQLSERVER_CONNECTION_STRING=
# Exemplo formato (sem valores):
# Server=${MSSQL_SERVER};Database=${MSSQL_DATABASE};User Id=${MSSQL_USER};Password=${MSSQL_PASSWORD};TrustServerCertificate=True
