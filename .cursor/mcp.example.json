{
  "_comment": "Exemplo agregado - copiar para .cursor/mcp.json local. NUNCA commitar tokens, senhas ou paths de usuario.",
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "clickup": {
      "type": "http",
      "url": "https://mcp.clickup.com/mcp"
    },
    "mssql": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@mcp-collection/mssql-mcp"],
      "env": {
        "HOST": "${MSSQL_HOST}",
        "PORT": "${MSSQL_PORT}",
        "USER": "${MSSQL_USER}",
        "PASSWORD": "${MSSQL_PASSWORD}",
        "DATABASE": "${MSSQL_DATABASE}",
        "TRUST_SERVER_CERTIFICATE": "${MSSQL_TRUST_SERVER_CERTIFICATE}"
      }
    },
    "mssql-fiscal": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@mcp-collection/mssql-mcp"],
      "env": {
        "HOST": "${MSSQL_FISCAL_HOST}",
        "PORT": "${MSSQL_FISCAL_PORT}",
        "USER": "${MSSQL_FISCAL_USER}",
        "PASSWORD": "${MSSQL_FISCAL_PASSWORD}",
        "DATABASE": "${MSSQL_FISCAL_DATABASE}",
        "TRUST_SERVER_CERTIFICATE": "${MSSQL_FISCAL_TRUST_SERVER_CERTIFICATE}"
      }
    }
  }
}
