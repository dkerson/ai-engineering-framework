# MCP Environment - Umbra (example)

> Copiar para `.env` na raiz do monorepo (`UMBRA/.env`).
> NUNCA commitar `.env` com valores reais.

# --- Context7 remote MCP ---
CONTEXT7_API_KEY=

# --- GitHub remote MCP ---
# Preferir OAuth do cliente. PAT somente fallback local quando o cliente nao suportar OAuth.
GITHUB_TOKEN=
GITHUB_OWNER=Otus7

# --- ClickUp remote MCP ---
# Preferir OAuth do cliente em https://mcp.clickup.com/mcp.
# Fallback legado apenas se algum cliente exigir token:
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=

# --- SQL Server principal (mssql / sqlserver-plugin) ---
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=
MSSQL_TRUST_SERVER_CERTIFICATE=true

# --- SQL Server fiscal (mssql-fiscal / sqlserver-plugin) ---
MSSQL_FISCAL_HOST=
MSSQL_FISCAL_PORT=1433
MSSQL_FISCAL_USER=
MSSQL_FISCAL_PASSWORD=
MSSQL_FISCAL_DATABASE=
MSSQL_FISCAL_TRUST_SERVER_CERTIFICATE=true

# --- Docker (docker-plugin) ---
DOCKER_HOST=
